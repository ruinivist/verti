#!/usr/bin/env bash
# verti-hooks
set -euo pipefail

VERTI_BIN={{ .VertiBinPath }}

LEGACY_HOOK={{ .LegacyHookPath }}

STATE="${1:-}"
TRANSACTION_INPUT="$(cat)"

if [ "${VERTI_BYPASS:-0}" = "0" ] && [ "$STATE" = "committed" ]; then
  "$VERTI_BIN" sync --debounced || true
fi

if [ -x "$LEGACY_HOOK" ]; then
  printf '%s' "$TRANSACTION_INPUT" | "$LEGACY_HOOK" "$@" || true
fi
