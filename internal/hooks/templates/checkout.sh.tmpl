#!/usr/bin/env bash
# verti-hooks
set -euo pipefail

VERTI_BIN={{ .VertiBinPath }}

LEGACY_HOOK={{ .LegacyHookPath }}

if [ "${VERTI_BYPASS:-0}" = "0" ]; then
  # post-checkout args: $1=old HEAD, $2=new HEAD, $3=1 branch checkout, $3=0 file checkout.
  # Restore only when checkout changed the commit.
  if [ "${3:-0}" = "1" ] && [ "${1:-}" != "${2:-}" ]; then
    "$VERTI_BIN" restore "${2}" || true
  fi
fi

[ -x "$LEGACY_HOOK" ] && "$LEGACY_HOOK" "$@"
